<Window x:Class="RoadCraftSaveEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoadCraftSaveEditor"
        mc:Ignorable="d"
        Title="RoadCraft Save Editor" Height="600" Width="900">
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- File Loading Section -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="LoadFileButton" Content="Load Save File" Padding="15,8" Click="LoadFileButton_Click"/>
            <Button x:Name="SaveFileButton" Content="Save File" Padding="15,8" Margin="10,0,0,0"
                    Click="SaveFileButton_Click" IsEnabled="False"/>
            <TextBlock x:Name="FilePathText" VerticalAlignment="Center" Margin="15,0,0,0"
                       Text="No file loaded" Foreground="Gray"/>
        </StackPanel>

        <!-- Navigation Section -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,10" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BackButton" Content="Back" Padding="10,4" Click="BackButton_Click" IsEnabled="False"/>
                <TextBlock x:Name="BreadcrumbText" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- JSON Editor Section -->
        <DataGrid Grid.Row="2"
                  x:Name="JsonGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  CellEditEnding="JsonGrid_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Key" Binding="{Binding Key}" IsReadOnly="True" Width="2*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ValueType}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Value" Binding="{Binding EditableValue, UpdateSourceTrigger=PropertyChanged}" Width="3*"/>
                <DataGridTemplateColumn Header="Action" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Open" Padding="8,3" Click="OpenChildButton_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
