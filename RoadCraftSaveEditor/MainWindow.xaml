<Window x:Class="RoadCraftSaveEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoadCraftSaveEditor"
        mc:Ignorable="d"
        Title="RoadCraft Save Editor" Height="600" Width="900">
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- File Loading Section -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="LoadFileButton" Content="Load Save File" Padding="15,8" Click="LoadFileButton_Click"/>
            <Button x:Name="SaveFileButton" Content="Save File" Padding="15,8" Margin="10,0,0,0"
                    Click="SaveFileButton_Click" IsEnabled="False"/>
            <TextBlock x:Name="FilePathText" VerticalAlignment="Center" Margin="15,0,0,0"
                       Text="No file loaded" Foreground="Gray"/>
        </StackPanel>

        <!-- Search Section -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="8" Margin="0,0,0,10" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="SearchTextBox" Width="250" Padding="4"
                         KeyDown="SearchTextBox_KeyDown"/>
                <Button Content="Find Next" Padding="10,4" Margin="8,0,0,0" Click="FindNextButton_Click"/>
                <Button Content="Find Previous" Padding="10,4" Margin="8,0,0,0" Click="FindPreviousButton_Click"/>
                <CheckBox x:Name="CaseSensitiveCheckBox" Content="Case Sensitive" VerticalAlignment="Center" Margin="15,0,0,0"/>
                <TextBlock x:Name="SearchStatusText" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Content Editor Section -->
        <TextBox Grid.Row="2" x:Name="ContentTextBox"
                 IsReadOnly="False"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 TextWrapping="NoWrap"
                 UndoLimit="100"/>
    </Grid>
</Window>
